{
  "manifest_version": 3,
  "name": "ChatGPT Direct Download URL",
  "version": "1.0.0",
  "description": "Перехватывает download?message_id в ChatGPT и извлекает download_url из JSON-ответа.",
  "permissions": [
    "debugger",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ChatGPT Direct Download",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
